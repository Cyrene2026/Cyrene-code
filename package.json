{
  "name": "cyrenecode",
  "version": "0.3.8",
  "description": "Terminal-first coding assistant with reviewable tool calls and rolling session state.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "homepage": "https://github.com/Cyrene2026/Cyrene-code#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cyrene2026/Cyrene-code.git"
  },
  "bugs": {
    "url": "https://github.com/Cyrene2026/Cyrene-code/issues"
  },
  "keywords": [
    "cli",
    "terminal",
    "assistant",
    "agent",
    "bun"
  ],
  "engines": {
    "node": ">=18",
    "bun": ">=1.1.0"
  },
  "files": [
    "bin/cyrene.js",
    "bin/lib/cyrene-cli.js",
    "dist",
    "src/application",
    "src/core",
    "src/infra",
    "src/shared",
    "src/frontend/components/v2/bridge.ts"
  ],
  "scripts": {
    "dev": "bun run v2:dev",
    "start": "node ./bin/cyrene.js",
    "build": "bun run scripts/build-cli.mjs",
    "token:audit": "bun run scripts/token-audit.mjs",
    "v2:dev": "mkdir -p /tmp/cyrene-go-cache && cd src/frontend/components/v2 && GOCACHE=/tmp/cyrene-go-cache go run .",
    "v2:build": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepack": "bun run build"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "node-pty": "^1.0.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@lydell/node-pty": "1.1.0",
    "@lydell/node-pty-darwin-arm64": "1.1.0",
    "@lydell/node-pty-darwin-x64": "1.1.0",
    "@lydell/node-pty-linux-x64": "1.1.0",
    "@lydell/node-pty-win32-arm64": "1.1.0",
    "@lydell/node-pty-win32-x64": "1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "node-pty"
  ],
  "bin": {
    "cyrene": "bin/cyrene.js"
  }
}
