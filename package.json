{
  "name": "cyrenecode",
  "version": "0.1.5",
  "description": "Terminal-first coding assistant with reviewable tool calls and rolling session state.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "homepage": "https://github.com/Cyrene2026/Cyrene-code#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cyrene2026/Cyrene-code.git"
  },
  "bugs": {
    "url": "https://github.com/Cyrene2026/Cyrene-code/issues"
  },
  "keywords": [
    "cli",
    "terminal",
    "assistant",
    "agent",
    "ink",
    "bun"
  ],
  "engines": {
    "node": ">=18",
    "bun": ">=1.1.0"
  },
  "files": [
    "bin",
    "dist",
    "assets/brand",
    "LICENSE",
    "README.md",
    "SECURITY.md"
  ],
  "scripts": {
    "dev": "bun --hot src/entrypoint/cli.tsx",
    "start": "bun src/entrypoint/cli.tsx",
    "build": "bun run scripts/build-cli.mjs",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepack": "bun run build"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "ink": "^5.0.1",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-test-renderer": "^18.3.0",
    "@types/bun": "latest",
    "react-test-renderer": "^18.3.1",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "node-pty"
  ],
  "bin": {
    "cyrene": "bin/cyrene.js"
  }
}
